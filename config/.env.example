# BibiGPT 转录服务
BIBIGPT_API_TOKEN=

# AI 改写接口（DeepSeek / OpenAI / 兼容接口）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# 语义搜索 Embedding（智谱 embedding-3；DeepSeek 无 embedding 接口故单独配置）
ZHIPU_API_KEY=            # 智谱开放平台 API Key（bigmodel.cn）
EMBED_MODEL=embedding-3
EMBED_DIM=1024

# 飞书开放平台
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=         # 多维表格 appToken（URL 中 /base/ 后面的字符串）
FEISHU_TABLE_ID=          # 多维表格 tableId（URL 中 ?table= 后面的字符串）

# 飞书文档同步（sync-doc 命令，可选）
FEISHU_DOC_FOLDER_TOKEN=  # 文档存放的云空间文件夹 token，留空则放个人根目录

# 归档目录
ARCHIVE_DIR=./archive

# 内容部署（scripts/deploy-content.sh，把本地 archive/索引镜像到线上服务器）
DEPLOY_SSH_HOST=          # SSH 目标，如 user@your-server 或 ~/.ssh/config 别名
DEPLOY_REMOTE_DIR=        # 服务器上的项目根目录，如 /srv/content-curation

# 每日简报失败/成功通知（飞书群自定义机器人，可选）
FEISHU_BOT_WEBHOOK=       # 群机器人 webhook 地址
FEISHU_BOT_SECRET=        # 机器人开启「签名校验」时填，否则留空

# 盘中巨热点监控（run.sh hot-watch，可选；全部有默认值）
HOT_WATCH_THRESHOLD=88        # AI HOT 讨论度阈值(0-100)，越高越安静
HOT_WATCH_WINDOW_HOURS=6      # 每轮拉取的时间窗口
HOT_WATCH_QUIET=              # 安静时段，如 23-8；留空=全天实时推送
